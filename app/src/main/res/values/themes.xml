<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Real theming lives in presentation/theme/Theme.kt (Compose). These XML themes only
         cover the tiny pre-Compose window needed for a flicker-free cold-start splash. -->
    <style name="Theme.Cadence" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.Cadence.Splash" parent="Theme.Cadence">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>
